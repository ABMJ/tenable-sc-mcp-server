# Docker Compose Configuration
# Set to your current user ID to avoid permission issues
LOCAL_UID=1000
LOCAL_GID=1000

# Tenable Security Center Configuration
# Replace with your actual Tenable.sc server URL and API credentials
TSC_URL=https://your-sc-server.com
TSC_ACCESS_KEY=your-access-key-here
TSC_SECRET_KEY=your-secret-key-here
TSC_VERIFY_SSL=true

# Cache Configuration
# Redis backend provides best performance for production deployments
TSC_CACHE_ENABLED=true
TSC_CACHE_BACKEND=redis
TSC_CACHE_REDIS_HOST=redis
TSC_CACHE_REDIS_PORT=6379
